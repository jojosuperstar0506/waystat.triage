# Copy to .env and fill in. Never commit .env to git.

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...    # service role key (server-side only — never expose to frontend)

# Gmail
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# CORS — set to your Vercel URL once deployed
ALLOWED_ORIGINS=http://localhost:3000,https://waystation-triage.vercel.app
